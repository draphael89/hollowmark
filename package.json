{
  "name": "hollowmark",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "asset:audit": "node scripts/audit-assets.mjs",
    "asset:contact-sheet": "node scripts/create-contact-sheet.mjs",
    "asset:matte-wolf": "node scripts/matte-sprite.mjs .curation/raw/underroot/batch-01/rootbitten-wolf-draft-01.png public/assets/drafts/underroot/batch-01/rootbitten-wolf-matte-preview-01.png 96 128 18",
    "asset:process-batch": "node scripts/process-underroot-batch.mjs",
    "test": "vitest run tests/*.test.ts",
    "test:browser": "playwright test",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify": "pnpm typecheck && pnpm test && pnpm build && pnpm test:browser"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  }
}
